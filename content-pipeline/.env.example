# Copy to .env and fill in. .env is gitignored.

# ── Ollama (required for pipeline.mjs and translate.mjs) ──────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# ── SMTP for daily-report.mjs (optional) ─────────────────────────────
# Gmail app password — get from myaccount.google.com/apppasswords
# (Requires 2FA enabled on the Google account first)
SMTP_USER=vitalii.nemyrovskyi@gmail.com
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
REPORT_TO=vitalii.nemyrovskyi@gmail.com

# ── Pexels API for per-article relevant images ───────────────────────
# Free signup at https://www.pexels.com/api/  (200 req/hr, 20K/month)
PEXELS_API_KEY=

# Copy to .env and fill in. .env is gitignored.

# ── LLM provider — REQUIRED ───────────────────────────────────────────
# Two modes:
#
# 1. **Fallback chain (recommended for prod)** — set LLM_PROVIDER_CHAIN
#    to a comma-separated list. Pipeline tries each in order; on
#    transient failure (429 / 5xx / empty) falls through to next.
#    Single TPD exhaustion no longer kills the run.
#
LLM_PROVIDER_CHAIN=groq,glm,gemini
#
# 2. **Single provider (legacy)** — set LLM_PROVIDER to one of:
#    groq | glm | gemini | ollama. Pipeline uses ONLY that one. If
#    LLM_PROVIDER_CHAIN is also set, the chain wins.
#
# LLM_PROVIDER=groq

# Groq path (default for prod since 2026-05-08):
LLM_PROVIDER=groq
GROQ_API_KEY=                              # https://console.groq.com — free tier 14 400 RPD
GROQ_MODEL=llama-3.3-70b-versatile         # 70B, free, ~1-3s per call
# GROQ_TRANSLATE_MODEL=llama-3.1-8b-instant   # smaller for translate.mjs (default)

# GLM path (z.ai — Chinese lab, distinct training distribution from
# Llama-family. Different writing style; useful as alternative when
# Groq's daily quota is hit, or for A/B output comparison):
# LLM_PROVIDER=glm
GLM_API_KEY=                               # https://docs.z.ai/guides/overview/quick-start — free tier
GLM_MODEL=glm-4.7-flash                    # 4.7-flash is permanently free (4.5-flash also works)
# GLM_BASE_URL=https://api.z.ai/api/paas/v4   # default — only override for proxies

# Ollama path (only if you've installed Ollama locally + pulled the model):
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3:70b

# Gemini fallback (read by some scripts, not required):
# GEMINI_API_KEY=                          # https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.0-flash

# ── SMTP for daily-report.mjs (optional) ─────────────────────────────
# Gmail app password — get from myaccount.google.com/apppasswords
# (Requires 2FA enabled on the Google account first)
SMTP_USER=vitalii.nemyrovskyi@gmail.com
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
REPORT_TO=vitalii.nemyrovskyi@gmail.com

# ── Pexels API for per-article relevant images ───────────────────────
# Free signup at https://www.pexels.com/api/  (200 req/hr, 20K/month)
PEXELS_API_KEY=
